version: "3.9"

services:
  foundry1:
    image: felddy/foundryvtt:release
    container_name: foundry1
    environment:
      - FOUNDRY_VERSION=13.351
      - CONTAINER_CACHE=/data/container_cache
      - FOUNDRY_ADMIN_KEY=admin_tavolo1
      - FOUNDRY_PORT=30000
    volumes:
      - ./tavolo1/data:/data
      - ./container-cache:/data/container_cache
    ports:
      - "30001:30000"
    dns:
      - 8.8.8.8
      - 1.1.1.1
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: "1.5"
          memory: "2G"
        reservations:
          memory: "1G"
  foundry2:
